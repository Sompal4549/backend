{
  "name": "ensis-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready ecommerce backend with Node.js, Express, MongoDB, JWT, and TypeScript.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server",
    "clean": "tsc --build --clean",
    "build": "tsc",
    "prestart": "npm run build",
    "start": "node dist/server.js",
    "lint": "eslint . --ext ",
    "seed": "tsx src/seeds/seed"
  },
  "keywords": [
    "ecommerce",
    "express",
    "nestjs",
    "mongodb",
    "typescript",
    "jwt"
  ],
  "author": "Ecommerce Architect",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.5.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.11.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.6.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "razorpay": "^2.9.6",
    "sharp": "^0.35.2",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.3",
    "@types/cors": "^2.8.14",
    "@types/express": "^4.17.17",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/morgan": "^1.9.4",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.14.2",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/yamljs": "^0.2.34",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.5",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.0",
    "ts-node": "^10.9.1",
    "tsx": "^4.22.3",
    "typescript": "^5.5.4"
